{
    "name": "gabebritto/laravel-simple-sqs",
    "description": "A Laravel package for asynchronous microservice communication via SQS with raw JSON payloads.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "gabebritto",
            "email": "gabrielsouto16@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "aws/aws-sdk-php": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Gabebritto\\LaravelSimpleSqs\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gabebritto\\LaravelSimpleSqs\\SqsMessengerServiceProvider"
            ],
            "aliases": {
                "SqsPublisher": "Gabebritto\\LaravelSimpleSqs\\Facades\\SqsPublisher"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}